rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Each device stores its data under users/{deviceId}/checkins
    // Anyone can read/write their own device path
    match /users/{deviceId}/checkins/{checkinId} {
      allow read, write: if request.time < timestamp.date(2026, 5, 25);
    }
  }
}
